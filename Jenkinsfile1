pipeline {
    agent any

    tools {
        jdk 'jdk21'
        nodejs 'node18'
    }

    environment {
        DOCKER_IMAGE = "rajeshtutta123/Book-my-show"
        RECIPIENTS = "rajeshtutta123@gmail.com"
        APP_NAME = "Book-my-show"
        APP_PORT = "3000"
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Clone Repo') {
            steps {
                git branch: 'main',
                url: 'https://github.com/rajeshtutta/Book-my-show.git'
            }
        }

        stage('Check Files') {
            steps {
                sh '''
                echo "Current Directory:"
                pwd

                echo "Listing Files:"
                ls -la

                echo "Finding package.json"
                find . -name package.json
                '''
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('bookmyshow-app') {

                    sh '''
                    rm -rf node_modules package-lock.json

                    npm install
                    '''
                }
            }
        }

        stage('Build Application') {
            steps {
                dir('bookmyshow-app') {

                    sh '''
                    npm run build
                    '''
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('bookmyshow-app') {

                    sh '''
                    npm test || true
                    '''
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {

                script {

                    def scannerHome = tool 'sonar-scanner'

                    withSonarQubeEnv('sq-token') {

                        dir('bookmyshow-app') {

                            sh """
                            ${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=bms \
                            -Dsonar.projectName=Book-my-show \
                            -Dsonar.sources=src \
                            -Dsonar.projectVersion=${BUILD_NUMBER}
                            """
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {

                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Package Artifact') {
            steps {

                dir('bookmyshow-app') {

                    sh '''
                    zip -r ../Book-my-show-build.zip build/
                    '''
                }
            }
        }

        stage('Upload to Nexus') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'nexus-cred',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASS'
                    )
                ]) {

                    sh '''
                    curl -v -u $NEXUS_USER:$NEXUS_PASS \
                    --upload-file Book-my-show-build.zip \
                    http://localhost:8081/repository/Book-my-show/Book-my-show-build-${BUILD_NUMBER}.zip
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {

                sh '''
                docker build \
                -t $DOCKER_IMAGE:${BUILD_NUMBER} \
                -t $DOCKER_IMAGE:latest \
                -f bookmyshow-app/Dockerfile \
                bookmyshow-app
                '''
            }
        }

        stage('Trivy Image Scan') {
            steps {

                sh '''
                trivy image $DOCKER_IMAGE:latest > trivyimage.txt
                '''
            }
        }

        stage('Docker Push') {
            steps {

                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-cred',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {

                    sh '''
                    echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin

                    docker push $DOCKER_IMAGE:${BUILD_NUMBER}

                    docker push $DOCKER_IMAGE:latest

                    docker logout
                    '''
                }
            }
        }

        stage('Deploy Container') {
            steps {

                sh '''
                echo "Stopping old container..."

                docker stop $APP_NAME || true

                docker rm $APP_NAME || true

                echo "Starting new container..."

                docker run -d \
                --restart=always \
                --name $APP_NAME \
                -p $APP_PORT:$APP_PORT \
                $DOCKER_IMAGE:latest

                echo "Running Containers"

                docker ps -a
                '''
            }
        }
    }

    post {

        success {

            emailext(
                subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                Build SUCCESSFUL

                Docker Image:
                ${DOCKER_IMAGE}:latest

                Application:
                http://3.110.230.95:3000

                Jenkins Build:
                ${env.BUILD_URL}
                """,

                to: "${RECIPIENTS}",

                attachmentsPattern: 'trivyimage.txt'
            )
        }

        failure {

            emailext(
                subject: "FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
                body: """
                Build FAILED

                Check Jenkins Logs:
                ${env.BUILD_URL}
                """,

                to: "${RECIPIENTS}"
            )
        }

        always {

            archiveArtifacts(
                artifacts: 'Book-my-show-build.zip',
                fingerprint: true
            )
        }
    }
}
